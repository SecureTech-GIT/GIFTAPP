[
  {
    "doctype": "Print Format",
    "name": "Delivered Gift Certificate",
    "doc_type": "Gift Issue",
    "print_format_type": "Server",
    "disabled": 0,
    "standard": "Yes",
    "html": "<style>:root {--bg: #f5f2eb;--card: #ffffff;--text: #111827;--muted: #6b7280;--border: #e5e7eb;--accent: #374151;--shadow: 0 12px 30px rgba(17, 24, 39, 0.08);}* {box-sizing: border-box;}.gcert-page {font-family: Inter, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, 'Apple Color Emoji', 'Segoe UI Emoji';color: var(--text);background: var(--bg);padding: 20px;}.gcert-card {background: var(--card);border: 1px solid var(--border);border-radius: 16px;overflow: hidden;box-shadow: var(--shadow);}.gcert-header {padding: 18px 24px;background: #f3f4f6;border-bottom: 1px solid var(--border);}.gcert-header-top {display: flex;justify-content: space-between;align-items: center;gap: 16px;}.gcert-brand-wrap {display: flex;align-items: center;gap: 14px;min-width: 0;}.gcert-logo {width: 96px;height: 96px;object-fit: contain;}.gcert-brand {font-size: 18px;letter-spacing: 0.14em;text-transform: uppercase;color: var(--accent);font-weight: 700;white-space: nowrap;overflow: hidden;text-overflow: ellipsis;}.gcert-meta {font-size: 12px;color: var(--muted);text-align: right;}.gcert-meta strong {color: var(--text);font-weight: 700;}.gcert-title {margin: 14px 0 0 0;font-size: 22px;line-height: 1.2;letter-spacing: 0.06em;text-transform: uppercase;color: var(--text);}.gcert-subtitle {margin-top: 6px;font-size: 12px;color: var(--muted);}.gcert-body {padding: 22px 24px 26px 24px;}.gcert-grid {width: 100%;border-collapse: separate;border-spacing: 0;border: 1px solid var(--border);border-radius: 12px;overflow: hidden;}.gcert-grid td {padding: 12px 14px;border-bottom: 1px solid var(--border);vertical-align: top;font-size: 13px;}.gcert-grid tr:last-child td {border-bottom: none;}.gcert-label {width: 32%;color: var(--muted);font-weight: 600;background: #f9fafb;}.gcert-value {font-weight: 700;color: var(--text);}.gcert-section-title {margin: 18px 0 10px 0;font-size: 12px;letter-spacing: 0.12em;text-transform: uppercase;color: var(--muted);font-weight: 800;}.gcert-attrs {width: 100%;border-collapse: separate;border-spacing: 0;border: 1px solid var(--border);border-radius: 12px;overflow: hidden;}.gcert-attrs th {text-align: left;padding: 10px 12px;font-size: 12px;color: var(--muted);background: #f3f4f6;border-bottom: 1px solid var(--border);}.gcert-attrs td {padding: 10px 12px;font-size: 13px;border-bottom: 1px solid var(--border);}.gcert-attrs tr:last-child td {border-bottom: none;}.gcert-muted {font-size: 12px;color: var(--muted);}.gcert-signatures {margin-top: 24px;display: flex;justify-content: space-between;}.gcert-signature {flex: 1;padding-top: 40px;}.gcert-signature-line {border-top: 1px solid #111827;padding-top: 8px;font-size: 12px;color: var(--muted);}</style><div class=\"gcert-page\">{% set gift_doc = frappe.get_doc('Gift', doc.gift) if doc.gift else None %}<div class=\"gcert-card\"><div class=\"gcert-header\"><div class=\"gcert-header-top\"><div class=\"gcert-brand-wrap\"><img class=\"gcert-logo\" src=\"/assets/gift/dist/imagelogo.png\" alt=\"Logo\" /></div><div class=\"gcert-meta\"><div><span>Issue:</span> <strong>{{ doc.name }}</strong></div><div style=\"margin-top:2px\"><span>Event:</span> <strong>{{ doc.event_name or doc.event or '' }}</strong></div></div></div><h1 class=\"gcert-title\">Certificate of Allocated Gift</h1><div class=\"gcert-subtitle\">This document confirms that the gift below has been allocated to the recipient.</div></div><div class=\"gcert-body\"><table class=\"gcert-grid\"><tr><td class=\"gcert-label\">Guest</td><td class=\"gcert-value\">{{ doc.guest_name or (doc.gift_recipient or '') }}</td></tr><tr><td class=\"gcert-label\">Gift</td><td class=\"gcert-value\">{{ doc.gift_name or (gift_doc.gift_name if gift_doc else doc.gift) }}</td></tr><tr><td class=\"gcert-label\">Category</td><td class=\"gcert-value\">{{ doc.category or (gift_doc.category if gift_doc else '') }}</td></tr><tr><td class=\"gcert-label\">Approved On</td><td class=\"gcert-value\">{{ doc.approved_on or '' }}</td></tr><tr><td class=\"gcert-label\">Delivered On</td><td class=\"gcert-value\">{{ doc.delivery_date or '' }}{% if doc.actual_delivery_time %} {{ doc.actual_delivery_time }}{% endif %}</td></tr></table><div class=\"gcert-section-title\">Gift Attributes</div>{% if gift_doc and gift_doc.table_gvlf %}<table class=\"gcert-attrs\"><tr><th style=\"width: 45%\">Attribute</th><th>Value</th></tr>{% for row in gift_doc.table_gvlf %}<tr><td><strong>{{ row.attribute_name }}</strong></td><td>{{ row.default_value or '' }}</td></tr>{% endfor %}</table>{% else %}<div class=\"gcert-muted\">No attributes found for this gift.</div>{% endif %}<div class=\"gcert-signatures\"><div class=\"gcert-signature\"><div class=\"gcert-signature-line\">Authorized Signature</div></div><div class=\"gcert-signature\"><div class=\"gcert-signature-line\">Receiver Signature</div></div></div></div></div></div>"
  }
]
